<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>CanonFlow.Core</PackageId>
    <Version>0.1.0-alpha</Version>
    <Authors>CanonFlow Foundation</Authors>
    <Description>Deterministic Semantic Infrastructure Core</Description>
    <RepositoryUrl>https://github.com/CanonFlowFoundation/CanonFlow</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Hash.fs" />
    <Compile Include="VerdictEnvelope.fs" />
    <Compile Include="CanonicalJson.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.UMX" Version="1.1.0" />
    <PackageReference Include="FsToolkit.ErrorHandling" Version="5.2.0" />
    <PackageReference Include="Thoth.Json.Net" Version="12.0.0" />
  </ItemGroup>

</Project>
